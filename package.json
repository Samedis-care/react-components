{
	"name": "components-care",
	"version": "0.1.0",
	"main": "dist",
	"types": "dist",
	"repository": "https://github.com/Samedis-care/react-components",
	"license": "Apache-2.0",
	"dependencies": {
		"@mui/icons-material": "^7.3.9",
		"@mui/material": "^7.3.9",
		"@mui/x-date-pickers": "^8.27.2",
		"@tanstack/react-query": "^5.96.1",
		"@types/node": "^25.5.0",
		"history": "^5.3.0",
		"hoist-non-react-statics": "^3.3.2",
		"i18next": "^26.0.3",
		"i18next-browser-languagedetector": "^8.2.1",
		"i18next-resources-to-backend": "^1.2.1",
		"libphonenumber-js": "^1.12.41",
		"moment": "^2.30.1",
		"react-color": "^2.19.3",
		"react-i18next": "^17.0.2",
		"react-ref-composer": "^1.0.1",
		"react-signature-pad-wrapper": "^4.3.2",
		"react-virtualized-auto-sizer": "^2.0.3",
		"react-window": "^2.2.7",
		"trim-canvas": "^0.1.2",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
	},
	"peerDependencies": {
		"@emotion/react": "^11.5.0",
		"@emotion/styled": "^11.3.0",
		"@sentry/react": "^9 || ^10",
		"@types/react": "^17 || ^18 || ^19",
		"@types/react-dom": "^17 || ^18 || ^19",
		"react": "^17 || ^18 || ^19",
		"react-dom": "^17 || ^18 || ^19"
	},
	"peerDependenciesMeta": {
		"@types/react": {
			"optional": true
		},
		"@types/react-dom": {
			"optional": true
		},
		"@sentry/react": {
			"optional": true
		},
		"@sentry/tracing": {
			"optional": true
		}
	},
	"scripts": {
		"docgen": "typedoc --exclude 'node_modules/**/*.*' --out typedoc --entryPoints src/index.ts",
		"start": "npm run storybook",
		"prestart": "husky install",
		"build": "tsc && cpx 'src/assets/**/*' dist/assets",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"build-ghpages": "bash build-ghpages.sh",
		"deploy-storybook": "storybook-to-ghpages -o storybook-static -s build-ghpages",
		"lint": "eslint 'src/**/*.{ts,tsx}'",
		"lint-fix": "eslint --fix 'src/**/*.{ts,tsx}'",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:unit": "vitest run --project unit",
		"test:stories": "vitest run --project storybook"
	},
	"sideEffects": false,
	"eslintConfig": {
		"extends": "react-app"
	},
	"lint-staged": {
		"(src|test)/**/*.{js,jsx,ts,tsx}": "eslint --max-warnings=0 --fix",
		"*.json": "prettier --write"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.1",
		"@eslint/compat": "^2.0.3",
		"@sentry/react": "^10.47.0",
		"@storybook/addon-a11y": "^10.3.4",
		"@storybook/addon-docs": "^10.3.4",
		"@storybook/addon-onboarding": "^10.3.4",
		"@storybook/addon-vitest": "^10.3.4",
		"@storybook/react-vite": "^10.3.4",
		"@testing-library/react": "^16.3.2",
		"@types/hoist-non-react-statics": "^3.3.7",
		"@types/react": "^19.2.14",
		"@types/react-color": "^3.0.13",
		"@types/react-dom": "^19.2.3",
		"@vitest/browser-playwright": "^4.1.2",
		"@vitest/coverage-v8": "^4.1.2",
		"cldr-data": "^36.0.5",
		"cpx2": "^8.0.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-storybook": "^10.3.4",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.1",
		"lint-staged": "^16.4.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"storybook": "^10.3.4",
		"typedoc": "^0.28.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.2"
	},
	"overrides": {
		"glob": "^11.1.0",
		"cldr-data-downloader@1.0.0-1": {
			"axios": "^1.12.2"
		}
	},
	"engines": {
		"npm": ">=10.x"
	}
}
